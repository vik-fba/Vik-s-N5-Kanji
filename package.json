{
  "name": "viks-kanji-n5",
  "version": "1.0.0",
  "description": "Vik's Kanji (N5) — Free kanji flashcard game",
  "main": "main.js",
  "author": "Víctor Fernández Bravo Ahuja <vikwebsadmin@gmail.com>",
  "license": "MIT",
  "homepage": "https://vikwebs.com",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder build --mac",
    "build:win": "electron-builder build --win",
    "build:linux": "electron-builder build --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.vikwebs.n5kanji",
    "productName": "Vik's Kanji",
    "copyright": "© 2025 Víctor Fernández Bravo Ahuja",
    "files": [
      "index.html",
      "main.js",
      "manifest.json",
      "sw.js",
      "icon-192.png",
      "icon-512.png"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "icon-512.png",
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "darkModeSupport": true
    },
    "win": {
      "icon": "icon-192.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "icon": "icon-192.png",
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Education"
    },
    "dmg": {
      "title": "Vik's Kanji (N5)"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
